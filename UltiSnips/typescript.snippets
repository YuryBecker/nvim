endsnippet


# ---- React Class ---- #
snippet rc
import * as React from 'react';
import { observer } from 'mobx-react';

import * as CSS from './css';


type Props = {};


@observer
export default class $1 extends React.Component <Props> {
    render() {
        return (
			<CSS.$1>
            </CSS.$1>
        );
    };
};
endsnippet


