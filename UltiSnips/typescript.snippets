# ---- Redux Actions ---- #
snippet actions "actions"
import types from 'types';


const local = {
};


const api = {
};


export default { name: '$1', actions: { ...api, ...local } };
endsnippet


# ---- Redux Middlware ---- #
snippet middleware "Middlware boilerplate"
import actions from 'actions';
import types from 'types';


export default ({ dispatch }) => next => A => {
    if (A.type === types.$1) {
		dispatch(actions.$2())
    }

    return next(A);
};
endsnippet


# ---- MobX ---- #
# Store
snippet store "MobX store"
import { action, computed, observable } from  'mobx';


export default class $1Store {
    root: Store.Root

    constructor(rootStore) {
        this.root = rootStore;
    };
};


declare global {
	namespace Store {
		type $1 = $1Store;
	}
}
endsnippet


# Inject
snippet inject "Inject MobX store"
