# Options:
# b: only expand at the beginning of a line.


# ---- Javascript ---- #
snippet ok "Object.keys()"
Object.keys(
endsnippet


snippet i "import" b;
import $1 from '$2';
endsnippet


snippet if "import from" b;
import { $1 } from '$2';
endsnippet

snippet c "const"
const 
endsnippet


snippet ec "export const"
export const 
endsnippet


# ---- React (simple ones) ---- #
snippet p "props"
props.$1
endsnippet


snippet tp "this props"
this.props.$1
endsnippet


snippet ts "this state"
this.state.$1
endsnippet


snippet v "style variable"
$1: ${ v.$2 };
endsnippet

snippet vm "@media"
${ v.mobile } {
	$1
}
endsnippet

snippet state "Typed state"
import getState from 'state';

const { store, dispatch } = getState();
endsnippet


snippet bi "background-image"
background-size: cover;
background-repeat: no-repeat;
background-position: 50% 50%;
background-image: url(${ props => props.$1 });
endsnippet


# ---- React Functional Component ---- #
snippet rf
